{
	"name": "@miketromba/ploof",
	"version": "0.1.3",
	"description": "AI asset generation CLI for OpenAI images today, designed for multi-provider creative workflows.",
	"type": "module",
	"bin": {
		"ploof": "dist/ploof.js"
	},
	"files": [
		"dist",
		"skills",
		"assets/brand/ploof-banner.png",
		"README.md",
		"LICENSE",
		"SPEC.md"
	],
	"scripts": {
		"dev": "bun run bin/ploof.ts",
		"build": "bun run scripts/build.ts",
		"test": "bun test tests/unit tests/integration",
		"test:watch": "bun test --watch",
		"test:unit": "bun test tests/unit",
		"test:integration": "bun test tests/integration",
		"test:e2e": "bun test tests/e2e",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"format": "bunx biome format --write .",
		"typecheck": "bunx tsc --noEmit",
		"prepublishOnly": "bun run lint && bun run typecheck && bun test && bun run build",
		"release": "bun run lint && bun run typecheck && bun test && bun run build && npm pack --dry-run",
		"ploof": "bun run bin/ploof.ts",
		"prepare": "husky || true"
	},
	"keywords": [
		"ai",
		"assets",
		"image-generation",
		"cli",
		"openai",
		"agent",
		"media-generation"
	],
	"author": "Michael Tromba",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/miketromba/ploof.git"
	},
	"bugs": {
		"url": "https://github.com/miketromba/ploof/issues"
	},
	"homepage": "https://github.com/miketromba/ploof#readme",
	"engines": {
		"node": ">=18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"husky": "^9.1.7",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"typescript": "^5 || ^6"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^13.1.0",
		"openai": "^6.45.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	}
}
