{
	"name": "ploof-monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=web",
		"dev:web": "turbo run dev --filter=web",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"cli": "bun --cwd packages/cli run ploof --",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"turbo": "^2.10.0"
	},
	"engines": {
		"node": ">=18"
	}
}
