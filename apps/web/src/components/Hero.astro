---
import { Image } from "astro:assets";
import mascot from "../assets/gallery/mascot.png";
import city from "../assets/gallery/city.png";
import blob from "../assets/gallery/blob.png";
import { INSTALL, LINKS } from "../consts";
import AgentPrompt from "./AgentPrompt.astro";
import Icon from "./Icon.astro";
---

<section class="relative overflow-hidden">
	<!-- ambient background -->
	<div class="pointer-events-none absolute inset-0 -z-10">
		<div class="aurora -left-32 -top-24 h-[28rem] w-[28rem] bg-peach"></div>
		<div class="aurora right-[-10rem] top-10 h-[30rem] w-[30rem] bg-violet-300"></div>
		<div class="aurora bottom-[-8rem] left-1/3 h-[24rem] w-[24rem] bg-violet-200"></div>
		<div class="absolute inset-0 bg-dots [mask-image:radial-gradient(70%_60%_at_50%_0%,black,transparent)]"></div>
	</div>

	<div class="container-px grid items-center gap-10 py-10 sm:py-14 lg:grid-cols-[1.08fr_0.92fr] lg:py-16">
		<!-- copy -->
		<div class="relative z-10">
			<h1 class="text-4xl font-extrabold leading-[1.07] sm:text-5xl">
				Generate images, video&nbsp;&amp; audio
				<span class="gradient-text">from your terminal.</span>
			</h1>

			<p class="mt-4 max-w-md text-lg leading-relaxed text-muted">
				Built to be run by your coding agent. Paste the prompt below into
				Claude&nbsp;Code, Cursor, or Codex — you're generating in seconds.
			</p>

			<div class="mt-6">
				<AgentPrompt />
			</div>

			<!-- secondary: manual install -->
			<div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
				<button
					type="button"
					class="copy-install group inline-flex items-center gap-2.5 rounded-full border border-violet-200 bg-white/70 px-4 py-2.5 font-mono text-sm text-ink backdrop-blur transition hover:border-violet-300 hover:bg-white"
					data-copy={INSTALL.bun}
					aria-label="Copy install command"
				>
					<span class="text-violet-400">$</span>
					<span>{INSTALL.bun}</span>
					<Icon name="copy" class="copy-icon h-4 w-4 text-muted transition group-hover:text-violet-600" />
					<Icon name="check" class="check-icon h-4 w-4 text-violet-600" />
				</button>
				<a href="/docs" class="inline-flex items-center gap-1.5 px-1 text-sm font-semibold text-violet-700 hover:text-violet-500">
					Read the docs <Icon name="arrowRight" class="h-4 w-4" />
				</a>
			</div>
		</div>

		<!-- mascot showcase -->
		<div class="relative z-0 mx-auto w-full max-w-md lg:max-w-none">
			<div class="relative aspect-square animate-float">
				<div class="absolute inset-6 -z-10 rounded-full bg-gradient-to-br from-peach/60 via-violet-200/60 to-violet-300/60 blur-2xl"></div>
				<Image
					src={mascot}
					alt="Ploof's mascot: a fluffy cloud holding a glowing terminal — generated by Ploof"
					widths={[320, 480, 640]}
					sizes="(max-width: 1024px) 22rem, 30rem"
					class="h-full w-full rounded-[2rem] object-contain drop-shadow-2xl"
					loading="eager"
				/>
			</div>

			<!-- floating sample chips -->
			<div class="absolute -left-2 bottom-6 w-40 rotate-[-6deg] sm:-left-6">
				<div class="card overflow-hidden p-1.5">
					<Image src={city} alt="" widths={[160, 320]} sizes="10rem" class="aspect-[3/2] w-full rounded-2xl object-cover" />
				</div>
			</div>
			<div class="absolute -right-1 top-4 w-28 rotate-[7deg] sm:right-2">
				<div class="card overflow-hidden p-1.5">
					<Image src={blob} alt="" widths={[112, 224]} sizes="7rem" class="aspect-square w-full rounded-2xl object-cover" />
				</div>
			</div>
			<div class="absolute -bottom-3 right-6 rounded-full border border-violet-100 bg-white/90 px-3 py-1.5 text-[11px] font-medium text-muted shadow-soft backdrop-blur">
				<span class="text-violet-500">✦</span> 100% generated by Ploof
			</div>
		</div>
	</div>
</section>

<style>
	.check-icon { display: none; }
	.copy-install.is-copied .check-icon { display: inline; }
	.copy-install.is-copied .copy-icon { display: none; }
</style>
