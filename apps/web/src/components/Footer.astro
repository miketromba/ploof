---
import { LINKS, SITE } from "../consts";
import Icon from "./Icon.astro";

const year = 2026;
---

<footer class="relative mt-24 border-t border-violet-100 bg-white/50">
	<div class="container-px grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
		<div class="lg:col-span-2">
			<a href="/" class="flex items-center gap-2.5 font-display text-lg font-extrabold text-ink">
				<img src="/mascot.png" alt="" width="32" height="32" class="h-8 w-8 rounded-lg" />
				Ploof
			</a>
			<p class="mt-3 max-w-xs text-sm text-muted">
				The agent-native CLI for generating images, video, and audio. Hand it to
				your agent and watch your ideas become files.
			</p>
		</div>

		<div>
			<h2 class="text-xs font-semibold tracking-wide text-muted uppercase">Product</h2>
			<ul class="mt-3 space-y-2 text-sm">
				<li><a href="/#gallery" class="text-ink/80 transition hover:text-violet-600">Gallery</a></li>
				<li><a href="/#features" class="text-ink/80 transition hover:text-violet-600">Features</a></li>
				<li><a href="/#quickstart" class="text-ink/80 transition hover:text-violet-600">Quickstart</a></li>
				<li><a href="/docs" class="text-ink/80 transition hover:text-violet-600">Docs</a></li>
			</ul>
		</div>

		<div>
			<h2 class="text-xs font-semibold tracking-wide text-muted uppercase">Open source</h2>
			<ul class="mt-3 space-y-2 text-sm">
				<li>
					<a href={LINKS.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink/80 transition hover:text-violet-600">
						<Icon name="github" class="h-4 w-4" /> GitHub
					</a>
				</li>
				<li>
					<a href={LINKS.npm} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-ink/80 transition hover:text-violet-600">
						<Icon name="npm" class="h-4 w-4" /> npm
					</a>
				</li>
				<li>
					<a href={LINKS.issues} target="_blank" rel="noopener" class="text-ink/80 transition hover:text-violet-600">Issues</a>
				</li>
				<li>
					<a href="/llms.txt" class="text-ink/80 transition hover:text-violet-600">llms.txt</a>
				</li>
			</ul>
		</div>
	</div>

	<div class="container-px flex flex-col items-center justify-between gap-3 border-t border-violet-100 py-6 text-xs text-muted sm:flex-row">
		<p>© {year} {SITE.author} · MIT licensed</p>
		<p class="inline-flex items-center gap-1.5">
			Every asset on this site was generated with
			<a href={LINKS.npm} target="_blank" rel="noopener" class="font-semibold text-violet-600">Ploof</a>
			<Icon name="sparkles" class="h-3.5 w-3.5 text-violet-400" />
		</p>
	</div>
</footer>
