---
import { Image } from "astro:assets";
import { GALLERY } from "../data/gallery";
import Icon from "./Icon.astro";
---

<section id="gallery" class="container-px scroll-mt-24 py-20 sm:py-24">
	<div class="mx-auto max-w-2xl text-center">
		<h2 class="text-3xl font-extrabold sm:text-4xl">
			Real assets. <span class="gradient-text">Real prompts.</span>
		</h2>
		<p class="mt-4 text-lg text-muted">
			Every image here was generated by Ploof — different styles, sizes, and
			subjects from one CLI. Hover any tile to see the exact prompt.
		</p>
	</div>

	<div class="mt-12 gap-5 [column-fill:_balance] sm:columns-2 lg:columns-3">
		{
			GALLERY.map((item) => (
				<figure class="group relative mb-5 block break-inside-avoid overflow-hidden rounded-3xl border border-violet-100 bg-white shadow-soft transition duration-300 hover:shadow-lift">
					<Image
						src={item.image}
						alt={item.alt}
						widths={[320, 480, 640]}
						sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
						class="w-full object-cover"
						loading="lazy"
					/>

					<div class="absolute left-3 top-3 flex items-center gap-1.5 rounded-full border border-white/40 bg-white/85 px-2.5 py-1 text-[11px] font-semibold text-violet-700 backdrop-blur">
						<Icon name="sparkles" class="h-3 w-3" /> {item.model}
					</div>

					<figcaption class="pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-[#1c172e]/92 via-[#1c172e]/35 to-transparent p-5 opacity-0 transition duration-300 group-hover:opacity-100">
						<p class="text-sm font-bold text-white">{item.title}</p>
						<p class="mt-1.5 line-clamp-4 text-[13px] leading-snug text-violet-100/90">
							<span class="font-mono text-violet-300">--prompt</span> “{item.prompt}”
						</p>
					</figcaption>
				</figure>
			))
		}
	</div>

	<p class="mt-8 text-center text-sm text-muted">
		Need motion or sound?
		<a href="#motion" class="font-semibold text-violet-700 hover:text-violet-500">See video &amp; audio ↓</a>
	</p>
</section>
